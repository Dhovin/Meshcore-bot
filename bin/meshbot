#!/usr/bin/env python3
import os
import sys
import json
import logging
import serial.tools.list_ports

try:
    if hasattr(sys.stdout, 'reconfigure'):
        sys.stdout.reconfigure(encoding='utf-8')
    if hasattr(sys.stderr, 'reconfigure'):
        sys.stderr.reconfigure(encoding='utf-8')
except Exception:
    pass

# Resolve project root and add to sys.path before importing core modules
script_dir = os.path.dirname(os.path.abspath(__file__))
project_root = os.path.abspath(os.path.join(script_dir, ".."))
if project_root not in sys.path:
    sys.path.insert(0, project_root)

from core.bot import MeshBot, SafeStreamWrapper
sys.stdout = SafeStreamWrapper(sys.stdout)
sys.stderr = SafeStreamWrapper(sys.stderr)

def load_module_schemas():
    import importlib.util
    modules_dir = "modules"
    resolved_base = os.path.abspath(modules_dir)
    schemas = {}
    if not os.path.exists(resolved_base):
        return schemas

    for file in os.listdir(resolved_base):
        if not file.endswith('.py') or file == '__init__.py' or file == 'template.py':
            continue
        full_path = os.path.abspath(os.path.join(resolved_base, file))
        module_name = os.path.splitext(file)[0]
        try:
            spec = importlib.util.spec_from_file_location(module_name, full_path)
            module = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(module)
            class_name = ''.join(x.title() for x in module_name.split('_'))
            ModuleClass = getattr(module, class_name, None)
            if not ModuleClass:
                ModuleClass = getattr(module, 'Module', None)
            if ModuleClass:
                instance = ModuleClass()
                if hasattr(instance, 'name') and instance.name:
                    schema = getattr(instance, 'config_schema', None)
                    schemas[instance.name] = {
                        "instance": instance,
                        "schema": schema,
                        "file": file
                    }
        except Exception:
            pass
    return schemas

def prompt_config_by_schema(schema, current_val, path=""):
    if not isinstance(schema, dict):
        return current_val
        
    s_type = schema.get("type")
    
    # If it's a simple type
    if s_type == "boolean":
        curr_str = "true" if current_val is True else ("false" if current_val is False else "default")
        val_input = input(f"  {path} (boolean) [current: {curr_str}] (t/f/y/n): ").strip().lower()
        if not val_input:
            return current_val
        return val_input in ("t", "true", "y", "yes")
        
    elif s_type in ("integer", "number"):
        curr_str = str(current_val) if current_val is not None else "default"
        val_input = input(f"  {path} ({s_type}) [current: {curr_str}]: ").strip()
        if not val_input:
            return current_val
        try:
            if s_type == "integer":
                return int(val_input)
            else:
                return float(val_input)
        except ValueError:
            print("Invalid number. Keeping current value.")
            return current_val
            
    elif s_type == "string":
        curr_str = str(current_val) if current_val is not None else "default"
        enum_list = schema.get("enum")
        if enum_list:
            print(f"  Choose for {path} (enum) [current: {curr_str}]:")
            for i, val in enumerate(enum_list):
                print(f"    {i + 1}) {val}")
            val_input = input(f"  Enter choice [1-{len(enum_list)}]: ").strip()
            if not val_input:
                return current_val
            if val_input.isdigit() and 1 <= int(val_input) <= len(enum_list):
                return enum_list[int(val_input) - 1]
            else:
                print("Invalid choice. Keeping current value.")
                return current_val
        else:
            val_input = input(f"  {path} (string) [current: {curr_str}]: ").strip()
            if not val_input and current_val is not None:
                return current_val
            return val_input
            
    elif s_type == "array":
        items_schema = schema.get("items", {})
        curr_str = json.dumps(current_val) if current_val is not None else "[]"
        print(f"  Editing array for {path} [current: {curr_str}]")
        val_input = input(f"  Enter comma-separated values for {path}: ").strip()
        if not val_input:
            return current_val
        parts = [x.strip() for x in val_input.split(",") if x.strip()]
        item_type = items_schema.get("type")
        if item_type == "integer":
            ret = []
            for p in parts:
                try:
                    ret.append(int(p))
                except ValueError:
                    pass
            return ret
        elif item_type == "number":
            ret = []
            for p in parts:
                try:
                    ret.append(float(p))
                except ValueError:
                    pass
            return ret
        else:
            return parts
            
    elif s_type == "object":
        properties = schema.get("properties", {})
        if not properties:
            return current_val
        if current_val is None:
            current_val = {}
        res_obj = dict(current_val)
        
        print(f"\n--- Configuring {path if path else 'object'} ---")
        for prop_name, prop_schema in properties.items():
            sub_path = f"{path}.{prop_name}" if path else prop_name
            res_obj[prop_name] = prompt_config_by_schema(prop_schema, res_obj.get(prop_name), sub_path)
        return res_obj
        
    return current_val

def configure_connection(current_conn):
    print("\n--- Connection Settings ---")
    print("Select Connection Type:")
    print("1) Auto-discovery (Serial -> BLE -> TCP fallback) [Recommended]")
    print("2) Serial")
    print("3) BLE (Bluetooth Low Energy)")
    print("4) TCP")
    
    choice = input("Enter choice [1-4, default 1]: ").strip()
    if not choice:
        conn_type = "auto"
    elif choice == "1":
        conn_type = "auto"
    elif choice == "2":
        conn_type = "serial"
    elif choice == "3":
        conn_type = "ble"
    elif choice == "4":
        conn_type = "tcp"
    else:
        print("Invalid choice, defaulting to 'auto'.")
        conn_type = "auto"
        
    conn_config = {
        "type": conn_type,
        "address": current_conn.get("address", ""),
        "port": current_conn.get("port", ""),
        "baudrate": current_conn.get("baudrate", 115200),
        "host": current_conn.get("host", "127.0.0.1"),
        "tcpPort": current_conn.get("tcpPort", 5000)
    }
    
    if conn_type == "serial":
        ports = list(serial.tools.list_ports.comports())
        if not ports:
            print("No serial ports detected on the system.")
            port_input = input(f"Enter serial port name (e.g. COM11 or /dev/ttyUSB0) [current: {conn_config['port']}]: ").strip()
            if port_input:
                conn_config["port"] = port_input
        else:
            print("\nAvailable Serial Ports:")
            for i, p in enumerate(ports):
                print(f"  {i + 1}) {p.device} - {p.description}")
            port_choice = input(f"Select port [1-{len(ports)}, current: {conn_config['port']}]: ").strip()
            if port_choice.isdigit() and 1 <= int(port_choice) <= len(ports):
                conn_config["port"] = ports[int(port_choice) - 1].device
            elif not port_choice and conn_config["port"]:
                pass
            else:
                port_input = input("Enter serial port name directly: ").strip()
                if port_input:
                    conn_config["port"] = port_input
        
        baud = input(f"Enter baudrate [current: {conn_config['baudrate']}]: ").strip()
        if baud.isdigit():
            conn_config["baudrate"] = int(baud)
            
    elif conn_type == "ble":
        print("Scanning BLE devices... (this may take a few seconds)")
        try:
            import asyncio
            from bleak import BleakScanner
            async def scan():
                return await BleakScanner.discover(timeout=3.0)
            
            devices = asyncio.run(scan())
            meshcore_devices = [d for d in devices if d.name and d.name.startswith("MeshCore-")]
            
            if not meshcore_devices:
                print("No BLE devices starting with 'MeshCore-' detected.")
                addr = input(f"Enter BLE Mac/UUID Address directly [current: {conn_config['address']}]: ").strip()
                if addr:
                    conn_config["address"] = addr
            else:
                print("\nAvailable BLE Nodes:")
                for i, d in enumerate(meshcore_devices):
                    print(f"  {i + 1}) {d.name} ({d.address})")
                ble_choice = input(f"Select node [1-{len(meshcore_devices)}, current: {conn_config['address']}]: ").strip()
                if ble_choice.isdigit() and 1 <= int(ble_choice) <= len(meshcore_devices):
                    conn_config["address"] = meshcore_devices[int(ble_choice) - 1].address
                elif not ble_choice and conn_config["address"]:
                    pass
                else:
                    addr = input("Enter BLE Mac/UUID Address directly: ").strip()
                    if addr:
                        conn_config["address"] = addr
        except ImportError:
            print("bleak library not installed or not supported on this platform.")
            addr = input(f"Enter BLE Mac/UUID Address [current: {conn_config['address']}]: ").strip()
            if addr:
                conn_config["address"] = addr
        except Exception as e:
            print(f"BLE Scan failed: {e}")
            addr = input(f"Enter BLE Mac/UUID Address [current: {conn_config['address']}]: ").strip()
            if addr:
                conn_config["address"] = addr
            
    elif conn_type == "tcp":
        host = input(f"Enter TCP host [current: {conn_config['host']}]: ").strip()
        if host:
            conn_config["host"] = host
        port_num = input(f"Enter TCP port [current: {conn_config['tcpPort']}]: ").strip()
        if port_num.isdigit():
            conn_config["tcpPort"] = int(port_num)
            
    return conn_config

def configure_core(current_core):
    print("\n--- Core Settings ---")
    core_config = {
        "timeSyncInterval": current_core.get("timeSyncInterval", "0 0 * * *"),
        "shutdownTimeoutMs": current_core.get("shutdownTimeoutMs", 10000),
        "ipcPort": current_core.get("ipcPort", 5002)
    }
    
    interval = input(f"Enter Time Sync Cron Interval [current: {core_config['timeSyncInterval']}]: ").strip()
    if interval:
        core_config["timeSyncInterval"] = interval
        
    timeout = input(f"Enter Shutdown Timeout in milliseconds [current: {core_config['shutdownTimeoutMs']}]: ").strip()
    if timeout.isdigit():
        core_config["shutdownTimeoutMs"] = int(timeout)
        
    ipc = input(f"Enter Local IPC Port [current: {core_config['ipcPort']}]: ").strip()
    if ipc.isdigit():
        core_config["ipcPort"] = int(ipc)
        
    return core_config

def configure_modules(current_modules):
    print("\n--- Modules Settings ---")
    schemas = load_module_schemas()
    if not schemas:
        print("No installed modules found.")
        return current_modules
        
    modules_config = dict(current_modules)
    
    while True:
        print("\nInstalled Modules:")
        module_list = sorted(schemas.keys())
        for i, mod_name in enumerate(module_list):
            is_enabled = modules_config.get(mod_name, {}).get("enabled", False)
            status = "ENABLED" if is_enabled else "DISABLED"
            print(f"  {i + 1}) {mod_name} [Status: {status}]")
        print(f"  {len(module_list) + 1}) Back")
        
        choice = input(f"Select a module to configure [1-{len(module_list) + 1}]: ").strip()
        if not choice or choice == str(len(module_list) + 1):
            break
            
        if choice.isdigit() and 1 <= int(choice) <= len(module_list):
            mod_name = module_list[int(choice) - 1]
            mod_schema = schemas[mod_name]["schema"]
            mod_config = modules_config.get(mod_name, {})
            
            while True:
                is_enabled = mod_config.get("enabled", False)
                status = "ENABLED" if is_enabled else "DISABLED"
                print(f"\n--- Configure Module: {mod_name} [{status}] ---")
                print("  1) Toggle Enable/Disable")
                print("  2) Edit Detailed Configuration Properties")
                print("  3) Back")
                
                sub_choice = input("Select option [1-3]: ").strip()
                if not sub_choice or sub_choice == "3":
                    break
                    
                if sub_choice == "1":
                    mod_config["enabled"] = not is_enabled
                    modules_config[mod_name] = mod_config
                    print(f"Module '{mod_name}' is now {'ENABLED' if mod_config['enabled'] else 'DISABLED'}.")
                elif sub_choice == "2":
                    instance = schemas[mod_name]["instance"]
                    if hasattr(instance, 'run_config') and callable(instance.run_config):
                        new_mod_config = instance.run_config(mod_config)
                    else:
                        if not mod_schema:
                            print(f"Module '{mod_name}' does not define a config schema or run_config method. Cannot edit properties.")
                            continue
                        new_mod_config = prompt_config_by_schema(mod_schema, mod_config, mod_name)
                    from core.validator import validate as validate_schema
                    errors = validate_schema(mod_schema, new_mod_config)
                    if errors:
                        print("\n[Error] Module configuration validation failed:")
                        for err in errors:
                            print(f"  - {err}")
                        print("Module settings changes were NOT applied.")
                    else:
                        mod_config = new_mod_config
                        modules_config[mod_name] = mod_config
                        print("Module configuration updated successfully.")
                        
    return modules_config

def run_config_wizard():
    print("==================================================")
    print("        MeshCore-bot Configuration Wizard         ")
    print("==================================================")
    
    config_path = "config/config.json"
    schema_path = "config/schema.json"
    
    if os.path.exists(config_path):
        with open(config_path, 'r') as f:
            try:
                full_config = json.load(f)
            except Exception:
                full_config = {}
    else:
        full_config = {}
        
    if "connection" not in full_config:
        full_config["connection"] = {
            "type": "auto",
            "address": "",
            "port": "",
            "baudrate": 115200,
            "host": "127.0.0.1",
            "tcpPort": 5000
        }
    if "core" not in full_config:
        full_config["core"] = {
            "timeSyncInterval": "0 0 * * *",
            "shutdownTimeoutMs": 10000,
            "ipcPort": 5002
        }
    if "modules" not in full_config:
        full_config["modules"] = {}
        
    while True:
        print("\nSelect Configuration Option:")
        print("1) Configure Connection Settings")
        print("2) Configure Core Settings (IPC, Time Sync, Shutdown Timeout)")
        print("3) Configure Installed Modules")
        print("4) Save & Exit")
        print("5) Discard & Exit")
        
        choice = input("Enter choice [1-5]: ").strip()
        if choice == "1":
            full_config["connection"] = configure_connection(full_config["connection"])
        elif choice == "2":
            full_config["core"] = configure_core(full_config["core"])
        elif choice == "3":
            full_config["modules"] = configure_modules(full_config["modules"])
        elif choice == "4":
            # Validate against schema
            from core.validator import validate as validate_schema
            if os.path.exists(schema_path):
                with open(schema_path, 'r') as f:
                    schema = json.load(f)
                errors = validate_schema(schema, full_config)
                if errors:
                    print("\n[Error] Schema validation failed for the configuration:")
                    for err in errors:
                        print(f"  - {err}")
                    print("Changes were NOT saved. Please correct the errors before saving.")
                    continue
            
            os.makedirs(os.path.dirname(config_path), exist_ok=True)
            with open(config_path, 'w') as f:
                json.dump(full_config, f, indent=2)
            print(f"\nConfiguration successfully validated and written to '{config_path}'")
            break
        elif choice == "5":
            print("\nConfiguration changes discarded.")
            break
        else:
            print("Invalid choice. Please choose between 1 and 5.")

def is_process_running(pid):
    if sys.platform == "win32":
        import ctypes
        PROCESS_QUERY_LIMITED_INFORMATION = 0x1000
        kernel32 = ctypes.windll.kernel32
        handle = kernel32.OpenProcess(PROCESS_QUERY_LIMITED_INFORMATION, False, pid)
        if handle:
            exit_code = ctypes.c_ulong()
            STILL_ACTIVE = 259
            if kernel32.GetExitCodeProcess(handle, ctypes.byref(exit_code)):
                is_active = (exit_code.value == STILL_ACTIVE)
                kernel32.CloseHandle(handle)
                return is_active
            kernel32.CloseHandle(handle)
            return True
        return False
    else:
        try:
            os.kill(pid, 0)
            return True
        except OSError:
            return False

def run_status():
    # If Linux and systemd service exists, delegate to systemctl status
    if sys.platform != "win32" and os.path.exists("/etc/systemd/system/meshcore-bot.service"):
        import subprocess
        print("Checking systemd service status...")
        subprocess.run(["sudo", "systemctl", "status", "meshcore-bot"])
        return

    config_path = "config/config.json"
    pid_path = "config/meshbot.pid"
    
    print("==================================================")
    print("           MeshCore-bot Daemon Status             ")
    print("==================================================")
    
    # Check if running
    running = False
    pid = None
    if os.path.exists(pid_path):
        try:
            with open(pid_path, 'r') as f:
                pid = int(f.read().strip())
            
            running = is_process_running(pid)
        except Exception:
            running = False
            
    if running:
        print(f"Status: RUNNING (PID: {pid})")
    else:
        print("Status: STOPPED")
        
    # Print configuration summary
    if os.path.exists(config_path):
        try:
            with open(config_path, 'r') as f:
                cfg = json.load(f)
            conn = cfg.get("connection", {})
            print("\nCurrent Configuration:")
            print(f"  Type:     {conn.get('type')}")
            if conn.get('type') == 'serial':
                print(f"  Port:     {conn.get('port')}")
                print(f"  Baudrate: {conn.get('baudrate')}")
            elif conn.get('type') == 'ble':
                print(f"  Address:  {conn.get('address')}")
            elif conn.get('type') == 'tcp':
                print(f"  Host:     {conn.get('host')}")
                print(f"  Port:     {conn.get('tcpPort')}")
            elif conn.get('type') == 'auto':
                print(f"  Fallback: BLE Addr: '{conn.get('address')}', TCP Host: '{conn.get('host')}:{conn.get('tcpPort')}'")
                
            core = cfg.get("core", {})
            print(f"  Time Sync Interval: {core.get('timeSyncInterval')}")
            
            modules = cfg.get("modules", {})
            enabled_mods = [name for name, mod in modules.items() if mod.get("enabled")]
            print(f"  Enabled Modules:    {', '.join(enabled_mods) if enabled_mods else 'None'}")
        except Exception as e:
            print(f"\nCould not read configuration: {e}")
    else:
        print("\nNo config.json found.")

def run_stop():
    pid_path = "config/meshbot.pid"
    
    # If Linux and systemd service exists, stop it via systemd
    if sys.platform != "win32" and os.path.exists("/etc/systemd/system/meshcore-bot.service"):
        import subprocess
        print("Stopping systemd service...")
        res = subprocess.run(["sudo", "systemctl", "stop", "meshcore-bot"])
        return res.returncode == 0
        
    if not os.path.exists(pid_path):
        print("No PID file found. Daemon is likely stopped.")
        return True
        
    try:
        with open(pid_path, 'r') as f:
            pid = int(f.read().strip())
    except Exception:
        print("Could not read PID file.")
        return False
        
    import signal
    if not is_process_running(pid):
        print(f"Process with PID {pid} is not running. Cleaning up PID file.")
        try:
            os.remove(pid_path)
        except Exception:
            pass
        return True
        
    print(f"Stopping daemon (PID {pid})...")
    try:
        os.kill(pid, signal.SIGTERM)
        # Wait up to 10 seconds for process to exit
        for _ in range(20):
            import time
            time.sleep(0.5)
            if not is_process_running(pid):
                print("Daemon stopped successfully.")
                if os.path.exists(pid_path):
                    try:
                        os.remove(pid_path)
                    except Exception:
                        pass
                return True
        print("Daemon did not stop in time. Force killing...")
        try:
            if sys.platform != "win32":
                os.kill(pid, signal.SIGKILL)
            else:
                os.kill(pid, signal.SIGTERM)
        except Exception:
            pass
        if os.path.exists(pid_path):
            try:
                os.remove(pid_path)
            except Exception:
                pass
        return True
    except Exception as e:
        print(f"Failed to stop daemon: {e}")
        return False

def run_restart():
    # If Linux and systemd service exists, restart it via systemd
    if sys.platform != "win32" and os.path.exists("/etc/systemd/system/meshcore-bot.service"):
        import subprocess
        print("Restarting systemd service...")
        subprocess.run(["sudo", "systemctl", "restart", "meshcore-bot"])
        return
        
    print("Restarting daemon...")
    run_stop()
    
    # Spawn a new process running meshbot start in the background
    import subprocess
    script_path = os.path.abspath(__file__)
    try:
        if sys.platform == "win32":
            subprocess.Popen(
                [sys.executable, script_path, "start"],
                creationflags=subprocess.CREATE_NEW_PROCESS_GROUP | subprocess.DETACHED_PROCESS,
                close_fds=True
            )
        else:
            subprocess.Popen(
                [sys.executable, script_path, "start"],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                preexec_fn=os.setpgrp,
                close_fds=True
            )
        print("Daemon restarted successfully in the background.")
    except Exception as e:
        print(f"Failed to spawn daemon: {e}")

def run_logs():
    # If Linux and systemd service exists, use journalctl
    if sys.platform != "win32" and os.path.exists("/etc/systemd/system/meshcore-bot.service"):
        import subprocess
        print("Streaming systemd service logs (Press Ctrl+C to exit)...")
        try:
            subprocess.run(["journalctl", "-u", "meshcore-bot", "-f"])
        except KeyboardInterrupt:
            pass
        return
        
    log_path = "config/meshbot.log"
    if not os.path.exists(log_path):
        print(f"No log file found at {log_path}.")
        return
        
    print(f"Streaming logs from {log_path} (Press Ctrl+C to exit)...")
    try:
        with open(log_path, 'r', encoding='utf-8', errors='ignore') as f:
            # Go to the end of the file
            f.seek(0, 2)
            end_pos = f.tell()
            # Read last 4KB to display recent lines
            f.seek(max(0, end_pos - 4096))
            lines = f.readlines()
            for line in lines[-50:]:
                print(line, end='')
                
            # Follow loop
            import time
            while True:
                line = f.readline()
                if not line:
                    time.sleep(0.1)
                    continue
                print(line, end='')
    except KeyboardInterrupt:
        print("\nExited log streaming.")

def run_modules():
    config_path = "config/config.json"
    modules_dir = "modules"
    
    print("==================================================")
    print("           MeshCore-bot Modules List              ")
    print("==================================================")
    
    # 1. Load enabled state from config.json
    enabled_mods = set()
    if os.path.exists(config_path):
        try:
            with open(config_path, 'r') as f:
                cfg = json.load(f)
            modules_cfg = cfg.get("modules", {})
            for name, mod in modules_cfg.items():
                if mod.get("enabled"):
                    enabled_mods.add(name)
        except Exception:
            pass
            
    # 2. Scan modules folder
    if not os.path.exists(modules_dir):
        print(f"Modules directory not found: {modules_dir}")
        return
        
    modules = []
    for file in os.listdir(modules_dir):
        if file.endswith('.py') and file != '__init__.py' and file != 'template.py':
            name = os.path.splitext(file)[0]
            status = "ENABLED" if name in enabled_mods else "DISABLED"
            modules.append((name, status))
            
    if not modules:
        print("No modules found in modules/ directory.")
    else:
        print(f"{'Module Name':<25} | {'Status':<10}")
        print("-" * 50)
        for name, status in sorted(modules):
            print(f"{name:<25} | {status:<10}")

def run_update():
    print("==================================================")
    print("              Updating MeshCore-bot               ")
    print("==================================================")
    
    # 1. Run git pull
    print("[Update] Pulling latest changes from Git repository...")
    import subprocess
    try:
        # Check if we have uncommitted changes
        status_res = subprocess.run(["git", "status", "--porcelain"], capture_output=True, text=True)
        has_changes = bool(status_res.stdout.strip())
        
        stashed = False
        if has_changes:
            print("[Update] Local uncommitted changes detected. Stashing changes...")
            stash_res = subprocess.run(["git", "stash"], capture_output=True, text=True)
            if stash_res.returncode == 0:
                stashed = True
                print("[Update] Local changes stashed successfully.")
            else:
                print("[Warning] Failed to stash local changes. Git pull might fail.")
                
        print("[Update] Executing git pull...")
        pull_res = subprocess.run(["git", "pull"], capture_output=True, text=True)
        print(pull_res.stdout)
        if pull_res.stderr:
            print(pull_res.stderr)
            
        if pull_res.returncode != 0:
            print("[Error] Git pull failed.")
            if stashed:
                print("[Update] Restoring stashed local changes...")
                subprocess.run(["git", "stash", "pop"])
            return False
            
        if stashed:
            print("[Update] Restoring stashed local changes...")
            pop_res = subprocess.run(["git", "stash", "pop"], capture_output=True, text=True)
            print(pop_res.stdout)
            
    except Exception as e:
        print(f"[Error] Exception occurred during Git pull: {e}")
        return False
        
    # 2. Update dependencies
    print("\n[Update] Updating Python dependencies...")
    try:
        subprocess.run([sys.executable, "-m", "pip", "install", "--upgrade", "pip", "setuptools", "wheel"])
        res = subprocess.run([sys.executable, "-m", "pip", "install", "pyserial", "bleak", "meshcore", "meshcore-cli"])
        if res.returncode == 0:
            print("[Update] Python dependencies updated successfully.")
        else:
            print("[Warning] Failed to update some Python dependencies.")
    except Exception as e:
        print(f"[Warning] Failed to update Python dependencies: {e}")
        
    # 3. Restart the daemon
    print("\n[Update] Restarting MeshCore-bot daemon...")
    run_restart()
    print("\n==================================================")
    print("MeshCore-bot updated and restarted successfully!")
    print("==================================================")
    return True

def start_daemon_process():
    import subprocess
    script_path = os.path.abspath(__file__)
    log_path = os.path.abspath("config/meshbot_bootstrap.log")
    try:
        f = open(log_path, "w", encoding="utf-8")
        if sys.platform == "win32":
            subprocess.Popen(
                [sys.executable, script_path, "start"],
                stdout=f,
                stderr=f,
                creationflags=subprocess.CREATE_NEW_PROCESS_GROUP | 0x00000008, # DETACHED_PROCESS
                close_fds=False
            )
        else:
            subprocess.Popen(
                [sys.executable, script_path, "start"],
                stdout=f,
                stderr=f,
                preexec_fn=os.setpgrp,
                close_fds=True
            )
        return True
    except Exception as e:
        print(f"Failed to spawn daemon process: {e}")
        return False

def print_cli_options():
    print("Usage: meshbot cli <command> [args...]")
    print()
    print("Available CLI commands:")
    print("  infos, -i                         - Print node information (firmware ver, model)")
    print("  self_telemetry, -t                - Print own telemetry details")
    print("  reboot                            - Reboot the node")
    print("  clock                             - Print current device time")
    print("  clock sync                        - Sync device clock with host system time")
    print("  msg, -m <name> <message>          - Send private message to a contact by name")
    print("  chan, -ch <index_or_name> <msg>   - Send message to a channel by index or name")
    print("  channels, -chans                  - Print all channel information")
    print("  set_channel <idx_or_nm> <nm> [k]  - Set/add channel info (nb, name, key_hex)")
    print("  remove_channel <idx_or_name>      - Remove channel (by index or name)")
    print("  set <setting> <value>             - Set setting (name, tx_power, pin, radio)")
    print("  contacts, -lc [-pub]              - Get persistent contact list")
    print("  reload_contacts, -rc              - Force reloading all contacts from node")

def run_cli_cmd(cmds):
    if not cmds:
        print("Error: No CLI command specified.")
        print_cli_options()
        return
        
    config_path = "config/config.json"
    pid_path = "config/meshbot.pid"
    
    # Normalize command name if it uses a dash shortcut (e.g. -i -> i, -lc -> lc)
    if cmds:
        first_cmd = cmds[0].lower()
        if first_cmd.startswith('-') and not first_cmd.startswith('--'):
            stripped = first_cmd[1:]
            if stripped in ("i", "t", "m", "ch", "lc", "rc", "chans"):
                cmds[0] = stripped
    
    # Check for -pub / --pub flags and strip them for contacts commands
    show_pub = False
    if cmds:
        has_contacts = any(token.lower() in ("contacts", "list", "lc", "reload_contacts", "rc") for token in cmds)
        if has_contacts:
            if "-pub" in cmds:
                show_pub = True
                cmds = [x for x in cmds if x != "-pub"]
            if "--pub" in cmds:
                show_pub = True
                cmds = [x for x in cmds if x != "--pub"]

    # Validate CLI command formatting client-side
    cmd_name = cmds[0].lower()
    if cmd_name in ("msg", "m"):
        if len(cmds) < 3:
            print("Error: Missing arguments for msg command.")
            print("Usage: meshbot cli msg <recipient_name> <message>")
            print()
            print_cli_options()
            return
    elif cmd_name in ("chan", "ch"):
        if len(cmds) < 3:
            print("Error: Missing arguments for chan command.")
            print("Usage: meshbot cli chan <channel_idx_or_name> <message>")
            print()
            print_cli_options()
            return
    elif cmd_name == "set":
        if len(cmds) < 3:
            print("Error: Missing arguments for set command.")
            print("Usage: meshbot cli set <setting> <value>")
            print()
            print_cli_options()
            return
    elif cmd_name == "set_channel":
        if len(cmds) < 3:
            print("Error: Missing arguments for set_channel command.")
            print("Usage: meshbot cli set_channel <idx_or_name> <name> [key_hex]")
            print()
            print_cli_options()
            return
    elif cmd_name == "add_channel":
        if len(cmds) < 2:
            print("Error: Missing arguments for add_channel command.")
            print("Usage: meshbot cli add_channel <name> [key_hex]")
            print()
            print_cli_options()
            return
    elif cmd_name == "remove_channel":
        if len(cmds) < 2:
            print("Error: Missing arguments for remove_channel command.")
            print("Usage: meshbot cli remove_channel <idx_or_name>")
            print()
            print_cli_options()
            return
    elif cmd_name in ("infos", "i", "query", "q", "ver", "reboot", "self_telemetry", "t", "reload_contacts", "rc"):
        if len(cmds) > 1:
            print(f"Error: Command '{cmds[0]}' does not accept extra arguments.")
            print(f"Usage: meshbot cli {cmds[0]}")
            print()
            print_cli_options()
            return
    elif cmd_name in ("contacts", "list", "lc"):
        if len(cmds) > 1:
            print(f"Error: Command '{cmds[0]}' only accepts the optional -pub flag.")
            print(f"Usage: meshbot cli {cmds[0]} [-pub]")
            print()
            print_cli_options()
            return
    elif cmd_name == "clock":
        if len(cmds) > 2 or (len(cmds) == 2 and cmds[1].lower() != "sync"):
            print("Error: Invalid arguments for clock command.")
            print("Usage: meshbot cli clock [sync]")
            print()
            print_cli_options()
            return
    elif cmd_name in ("channels", "chans", "get_channels"):
        if len(cmds) > 1:
            print(f"Error: Command '{cmds[0]}' does not accept extra arguments.")
            print(f"Usage: meshbot cli {cmds[0]}")
            print()
            print_cli_options()
            return
    elif cmd_name not in (
        "infos", "i", "query", "q", "ver", "reboot", "self_telemetry", "t",
        "clock", "msg", "m", "chan", "ch", "channels", "chans", "get_channels",
        "set_channel", "add_channel", "remove_channel", "set",
        "contacts", "list", "lc", "reload_contacts", "rc"
    ):
        print(f"Error: Unrecognized CLI command '{cmds[0]}'.")
        print_cli_options()
        return

    # 1. Check if daemon is running
    running = False
    if os.path.exists(pid_path):
        try:
            with open(pid_path, 'r') as f:
                pid = int(f.read().strip())
            running = is_process_running(pid)
        except Exception:
            pass
            
    if not running:
        print("Daemon is not running. Starting MeshCore-bot daemon in the background...")
        if not start_daemon_process():
            print("Error: Could not start the daemon process.")
            return

    # 2. Connect/poll daemon IPC server
    import socket
    import time
    
    ipc_port = 5002
    if os.path.exists(config_path):
        try:
            with open(config_path, 'r') as f:
                cfg = json.load(f)
            ipc_port = cfg.get("core", {}).get("ipcPort", 5002)
        except Exception:
            pass

    connected = False
    start_time = time.time()
    timeout = 10.0 # wait up to 10 seconds for the daemon to start and initialize
    
    s = None
    while time.time() - start_time < timeout:
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(2.0)
            s.connect(('127.0.0.1', ipc_port))
            connected = True
            break
        except Exception:
            if s:
                s.close()
            time.sleep(0.25)
            
    if not connected:
        print(f"Error: Could not connect to daemon IPC server on port {ipc_port} after {timeout} seconds.")
        print("Please check the logs in config/meshbot.log for connection or configuration errors.")
        return

    try:
        s.settimeout(60.0)
        payload = json.dumps({"command": cmds}).encode('utf-8')
        s.sendall(payload)
        s.shutdown(socket.SHUT_WR)
        
        response_data = b""
        while True:
            chunk = s.recv(4096)
            if not chunk:
                break
            response_data += chunk
        s.close()
        
        if response_data:
            res = json.loads(response_data.decode('utf-8'))
            if isinstance(res, dict) and "error" in res:
                print(f"Error: {res['error']}")
                err_msg = res["error"].lower()
                if "usage:" in err_msg or "unsupported command" in err_msg or "invalid" in err_msg or "missing" in err_msg:
                    print()
                    print_cli_options()
            elif cmds and cmds[0].lower() in ("contacts", "list", "lc", "reload_contacts", "rc") and isinstance(res, dict):
                type_map = {
                    1: "Companion",
                    2: "Repeater",
                    3: "Room Server",
                    4: "Sensor"
                }
                if show_pub:
                    print(f"{'Contact Name':<30} | {'Type':<15} | {'Public Key'}")
                    print("-" * 115)
                else:
                    print(f"{'Contact Name':<30} | {'Type':<15}")
                    print("-" * 50)
                sorted_contacts = sorted(res.values(), key=lambda x: x.get("adv_name", "").lower())
                for c in sorted_contacts:
                    name = c.get("adv_name") or c.get("name") or "Unknown"
                    t_val = c.get("type", 1)
                    t_str = type_map.get(t_val, f"Unknown ({t_val})")
                    if show_pub:
                        pubkey = c.get("public_key") or "N/A"
                        print(f"{name:<30} | {t_str:<15} | {pubkey}")
                    else:
                        print(f"{name:<30} | {t_str:<15}")
            elif cmds and cmds[0].lower() in ("channels", "chans", "get_channels") and isinstance(res, list):
                for c in res:
                    if c.get("channel_name") != "":
                        print(f"{c.get('channel_idx')}: {c.get('channel_name')} [{c.get('channel_secret')}]")
            else:
                if isinstance(res, (dict, list)):
                    print(json.dumps(res, indent=2))
                else:
                    print(res)
        else:
            print("Error: Received empty response from daemon.")
    except Exception as e:
        print(f"Error executing command via daemon IPC: {e}")

def print_main_help():
    print("Usage: meshbot [start|stop|restart|config|status|logs|modules|update|cli]")
    print("  start         - Start the daemon (runs systemd service on Linux, foreground on Windows)")
    print("  start-daemon  - Run the bot daemon process in the foreground (used by systemd)")
    print("  stop          - Stop the running daemon")
    print("  restart       - Restart the daemon")
    print("  config        - Interactive terminal configuration wizard")
    print("  status        - Print bot status and connection info")
    print("  logs          - Stream/view troubleshooting logs (calls journalctl on Linux)")
    print("  modules       - List all available modules in modules/ and their status")
    print("  update        - Pull latest changes from Git, update dependencies, and restart daemon")
    print("  cli           - Run a direct CLI command on the hardware (e.g., meshbot cli set name MyNode)")

def main():
    args = sys.argv[1:]
    
    # Normalize paths so we look in the project workspace
    script_dir = os.path.dirname(os.path.abspath(__file__))
    project_root = os.path.abspath(os.path.join(script_dir, ".."))
    os.chdir(project_root)
    
    if not args:
        cmd = "help"
    else:
        cmd = args[0]
        
    if cmd == "start-daemon":
        if len(args) > 1:
            print("Error: Command 'start-daemon' does not accept arguments.")
            print("Usage: meshbot start-daemon")
            print()
            print_main_help()
            sys.exit(1)
        bot = MeshBot()
        success = bot.run()
        sys.exit(0 if success else 1)
    elif cmd == "start":
        if len(args) > 1:
            print("Error: Command 'start' does not accept arguments.")
            print("Usage: meshbot start")
            print()
            print_main_help()
            sys.exit(1)
        if sys.platform != "win32" and os.path.exists("/etc/systemd/system/meshcore-bot.service"):
            import subprocess
            print("Starting systemd service...")
            res = subprocess.run(["sudo", "systemctl", "start", "meshcore-bot"])
            sys.exit(res.returncode)
        else:
            bot = MeshBot()
            success = bot.run()
            sys.exit(0 if success else 1)
    elif cmd == "stop":
        if len(args) > 1:
            print("Error: Command 'stop' does not accept arguments.")
            print("Usage: meshbot stop")
            print()
            print_main_help()
            sys.exit(1)
        success = run_stop()
        sys.exit(0 if success else 1)
    elif cmd == "restart":
        if len(args) > 1:
            print("Error: Command 'restart' does not accept arguments.")
            print("Usage: meshbot restart")
            print()
            print_main_help()
            sys.exit(1)
        run_restart()
        sys.exit(0)
    elif cmd == "config":
        if len(args) > 1:
            print("Error: Command 'config' does not accept arguments.")
            print("Usage: meshbot config")
            print()
            print_main_help()
            sys.exit(1)
        run_config_wizard()
        sys.exit(0)
    elif cmd == "status":
        if len(args) > 1:
            print("Error: Command 'status' does not accept arguments.")
            print("Usage: meshbot status")
            print()
            print_main_help()
            sys.exit(1)
        run_status()
        sys.exit(0)
    elif cmd == "logs":
        if len(args) > 1:
            print("Error: Command 'logs' does not accept arguments.")
            print("Usage: meshbot logs")
            print()
            print_main_help()
            sys.exit(1)
        run_logs()
        sys.exit(0)
    elif cmd == "modules":
        if len(args) > 1:
            print("Error: Command 'modules' does not accept arguments.")
            print("Usage: meshbot modules")
            print()
            print_main_help()
            sys.exit(1)
        run_modules()
        sys.exit(0)
    elif cmd == "update":
        if len(args) > 1:
            print("Error: Command 'update' does not accept arguments.")
            print("Usage: meshbot update")
            print()
            print_main_help()
            sys.exit(1)
        success = run_update()
        sys.exit(0 if success else 1)
    elif cmd == "cli":
        run_cli_cmd(args[1:])
        sys.exit(0)
    elif cmd in ("--help", "-h", "help"):
        print_main_help()
        sys.exit(0)
    else:
        print(f"Unknown command: {cmd}")
        print_main_help()
        sys.exit(1)

if __name__ == '__main__':
    main()
