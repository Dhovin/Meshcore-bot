{
  "connection": {
    "type": "auto",
    "address": "",
    "port": "",
    "baudrate": 115200,
    "host": "127.0.0.1",
    "tcpPort": 5000
  },
  "core": {
    "timeSyncInterval": "0 0 * * *",
    "shutdownTimeoutMs": 10000,
    "ipcPort": 5002
  },
  "modules": {
    "autoresponce": {
      "enabled": true,
      "channels": [
        "#test",
        "#testing"
      ]
    },
    "template": {
      "enabled": true,
      "messagePrefix": "[MeshBot]",
      "logChannel": 0
    },
    "weather_bot": {
      "enabled": true,
      "weatherAlarm": "06:00",
      "zipCode": "76246",
      "channels": {
        "alerts": "#weather",
        "weather": "#weather"
      },
      "timers": {
        "blitzCollection": 600000,
        "meteoAlerts": 600000
      },
      "blitzRadiusMiles": 10,
      "meteoAlerts": {
        "enabled": true,
        "timeout": 180,
        "severityFilter": [
          "severe",
          "extreme"
        ],
        "certaintyFilter": [
          "observed",
          "likely"
        ],
        "messageTemplate": "{event} Alert for {region}\nEffective: {start} to {end}\nSeverity: {severity}\n{headline}"
      }
    },
    "mqtt": {
      "enabled": true,
      "verbose": true,
      "debug": true,
      "iata": "DFW",
      "output_file": "",
      "brokers": [
        {
          "server": "ntxmesh.dhovin.me",
          "port": 1883,
          "use_tls": false
        }
      ]
    }
  }
}
